# =============================================================
#  ExpenseFlow — Configurações do Backend
#  Copie este arquivo para .env e preencha com seus dados.
#  ⚠️  NUNCA commite o .env — ele contém credenciais reais!
# =============================================================


# -------------------------------------------------------------
#  UiPath Orchestrator
#  Como obter: cloud.uipath.com → Admin → External Applications
# -------------------------------------------------------------
ORCHESTRATOR_URL=https://cloud.uipath.com
UIPATH_ORG=seu_org_aqui
UIPATH_TENANT=seu_tenant_aqui
UIPATH_CLIENT_ID=seu_client_id_aqui
UIPATH_CLIENT_SECRET=seu_client_secret_aqui
UIPATH_FOLDER_ID=seu_folder_id_aqui
UIPATH_PROCESS_NAME=ExpenseFlow


# -------------------------------------------------------------
#  Contas de e-mail conectadas ao UiPath Integration Service
#
#  Como obter o Connection ID:
#  UiPath Studio → Integration Service → Connections
#  → Clique na conexão → copie o ID da URL ou do painel
#
#  Adicione quantas contas quiser (CONTA_1, CONTA_2, CONTA_3...)
# -------------------------------------------------------------
CONTA_1_LABEL=seu_email@gmail.com
CONTA_1_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# CONTA_2_LABEL=outro_email@gmail.com
# CONTA_2_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# CONTA_3_LABEL=email_outlook@hotmail.com
# CONTA_3_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx


# -------------------------------------------------------------
#  Opcional — Caminho do Excel
#  Deixe em branco para usar o caminho automático do projeto.
#  Preencha apenas se o Excel estiver em outro local.
# -------------------------------------------------------------
# EXCEL_PATH=C:\caminho\customizado\ExpenseFlow_Dados.xlsx


# -------------------------------------------------------------
#  Opcional — Porta do servidor (padrão: 8000)
# -------------------------------------------------------------
# PORT=8000