# ==============================================================
#  ExpenseFlow 2.0 — Template de Configuração
#  INSTRUÇÕES: Copie este arquivo como ".env" e preencha
#  com os seus próprios dados. NUNCA suba o .env para o Git.
# ==============================================================

# --- UiPath Orchestrator ---
ORCHESTRATOR_URL=https://cloud.uipath.com
UIPATH_ORG=seu_org_aqui
UIPATH_TENANT=seu_tenant_aqui
UIPATH_CLIENT_ID=seu_client_id_aqui
UIPATH_CLIENT_SECRET=seu_client_secret_aqui
UIPATH_FOLDER_ID=seu_folder_id_aqui
UIPATH_PROCESS_NAME=ExpenseFlow

# --- Contas Gmail (adicione quantas quiser no padrão abaixo) ---
# Formato: GMAIL_CONTA_N e GMAIL_CONNECTION_ID_N (onde N = 1, 2, 3...)
GMAIL_CONTA_1=seu_email@gmail.com
GMAIL_CONNECTION_ID_1=seu_connection_id_gmail_1_aqui

GMAIL_CONTA_2=segundo_email@gmail.com
GMAIL_CONNECTION_ID_2=seu_connection_id_gmail_2_aqui

# --- Como encontrar o Connection ID ---
# 1. Acesse cloud.uipath.com → Seu tenant → Integrations → Connections
# 2. Localize a conexão Gmail ou Outlook
# 3. Copie o ID exibido na URL ou nos detalhes da conexão
